{

  "schemaVersion": 1,

  "id": "sguprofiler",

  "version": "${version}",

  "name": "SGUProfiler",

  "description": "服务端实体刻采样",

  "authors": ["MiYui","AntiDeath"],

  "license": "MIT",

  "environment": "server",

  "entrypoints": {

