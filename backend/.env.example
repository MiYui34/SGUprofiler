# Copy to ".env" and fill with long random strings (>=16 chars each).
# SESSION_SECRET: browser login session signing
# SGUPROF_INGEST_SECRET: HMAC key for POST /api/v1/ingest. Put the same value in the Minecraft server's config/sguprofiler.json as "ingestSecret" (UTF-8), or override via env SGUPROF_INGEST_SECRET / JVM -Dsguprof.ingestSecret=....

SESSION_SECRET=change_me_generate_with_python_secrets_token_urlsafe_48
SGUPROF_INGEST_SECRET=change_me_same_value_as_mod_ingestSecret
